{
  "name": "abhik-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev --local --port 8787",
    "dev:vite": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "deploy": "npm run build && wrangler deploy",
    "wrangler:dev": "wrangler dev --local --port 8787",
    "db:migrate:local": "wrangler d1 migrations apply portfolio-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply portfolio-db --remote",
    "db:seed:local": "node scripts/import-legacy-data.mjs --local",
    "db:seed:remote": "node scripts/import-legacy-data.mjs --remote",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.24",
    "eslint": "9.38.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5",
    "vite": "^7.2.7",
    "wrangler": "^4.52.0"
  }
}
